# Custom local Suricata rules for attacker -> victim

# 1. Port scanning
alert tcp 172.28.0.10 any -> 172.28.0.20 [21,22,23,80] (msg:"LOCAL Port scan from attacker"; flow:to_server,stateless; flags:S; threshold:type both, track by_src, count 5, seconds 10; sid:1000001; rev:2;)

# 2. FTP attack traffic
alert tcp 172.28.0.10 any -> 172.28.0.20 21 (msg:"LOCAL FTP from attacker"; flow:to_server,stateless; flags:S; sid:1000002; rev:2;)

# 3. Telnet attack traffic
alert tcp 172.28.0.10 any -> 172.28.0.20 23 (msg:"LOCAL Telnet from attacker"; flow:to_server,stateless; flags:S; sid:1000003; rev:2;)

# 4. DNS attack traffic
alert udp 172.28.0.10 any -> 172.28.0.20 53 (msg:"LOCAL DNS from attacker"; sid:1000004; rev:1;)

# 5. NetBIOS scanning
alert udp 172.28.0.10 any -> 172.28.0.20 [137,138,139] (msg:"LOCAL NetBIOS from attacker"; sid:1000005; rev:1;)

# 6. TFTP attack traffic
alert udp 172.28.0.10 any -> 172.28.0.20 69 (msg:"LOCAL TFTP from attacker"; sid:1000006; rev:1;)

# 7. Repeated SSH connection attempts (hydra / brute-force simulation)
alert tcp 172.28.0.10 any -> 172.28.0.20 22 (msg:"LOCAL Possible SSH brute-force / repeated connection attempts"; flow:to_server,stateless; flags:S; threshold:type both, track by_src, count 5, seconds 60; sid:1000007; rev:2;)

# 8. Nikto detection based on HTTP User-Agent
alert http 172.28.0.10 any -> 172.28.0.20 80 (msg:"LOCAL Nikto web scan detected"; flow:to_server,established; http.user_agent; content:"Nikto"; nocase; sid:1000008; rev:1;)

# 9. Nmap NSE / service detection based on HTTP User-Agent
alert http 172.28.0.10 any -> 172.28.0.20 80 (msg:"LOCAL Nmap service detection"; flow:to_server,established; http.user_agent; content:"Nmap"; nocase; sid:1000009; rev:1;)

# 10. Generic HTTP from attacker
alert http 172.28.0.10 any -> 172.28.0.20 80 (msg:"LOCAL HTTP from attacker"; flow:to_server,established; sid:1000010; rev:1;)

# 11. Simple SQL injection pattern in HTTP URI: UNION
alert http 172.28.0.10 any -> 172.28.0.20 80 (msg:"LOCAL SQL injection pattern detected (UNION)"; flow:to_server,established; http.uri; content:"union"; nocase; sid:1000011; rev:1;)

# 12. Simple SQL injection pattern in HTTP URI: OR 1=1
alert http 172.28.0.10 any -> 172.28.0.20 80 (msg:"LOCAL SQL injection pattern detected (OR 1=1)"; flow:to_server,established; http.uri; content:"or 1=1"; nocase; sid:1000012; rev:1;)